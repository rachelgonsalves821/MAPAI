# Backend Environment Configuration
# Copy to .env and fill in real values
# NEVER commit .env with real secrets

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
# Set SKIP_AUTH=true to disable JWT verification in local dev (NODE_ENV must be 'development')
SKIP_AUTH=true

# Supabase (auth + database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret

# Supabase Direct DB (for migrations only)
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PORT=6543
SUPABASE_DB_PASSWORD=your_db_password

# LLM Provider: 'gemini' (cheap+fast) or 'anthropic' (higher quality)
LLM_PROVIDER=gemini

# Anthropic Claude (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6

# Google Gemini (used when LLM_PROVIDER=gemini)
GOOGLE_GEMINI_API_KEY=your_google_api_key

# Ordered list of Gemini models to try on transient failures (429, 503, timeout, etc.)
# The retry layer attempts each model in sequence with exponential-backoff retries.
# If unset, falls back to GEMINI_MODEL (+ optional GEMINI_FALLBACK_MODEL).
# GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-1.5-flash

# Legacy single-model vars — used only when GEMINI_MODELS is not set.
GEMINI_MODEL=gemini-2.0-flash
# GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# Per-attempt timeout in ms. Each model and each retry get this full budget (default 30000).
# GEMINI_TIMEOUT_MS=30000

# Max retries per model before moving to the next one (default 2).
# GEMINI_MAX_RETRIES_PER_MODEL=2

# Set to 'false' to disable falling back to non-Gemini providers after all Gemini models fail.
# GEMINI_ENABLE_FALLBACK_PROVIDER=true

# Google Places
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Redis (optional — falls back to in-memory cache)
REDIS_URL=redis://localhost:6379

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:8081
