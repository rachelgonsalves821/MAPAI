{
    "name": "mapai-backend",
    "version": "0.1.0",
    "description": "Mapai Backend API — AI discovery & navigation for Boston",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "lint": "eslint src/ --ext .ts",
        "typecheck": "tsc --noEmit",
        "migrate": "tsx src/db/migrate.ts",
        "seed": "tsx src/db/seed.ts"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.39.0",
        "@supabase/supabase-js": "^2.49.0",
        "fastify": "^5.2.0",
        "@fastify/cors": "^10.0.0",
        "@fastify/websocket": "^11.0.0",
        "@fastify/rate-limit": "^10.2.0",
        "ioredis": "^5.4.2",
        "jsonwebtoken": "^9.0.2",
        "uuid": "^11.1.0",
        "zod": "^3.24.0",
        "dotenv": "^16.4.7"
    },
    "devDependencies": {
        "@types/jsonwebtoken": "^9.0.9",
        "@types/node": "^22.13.0",
        "@types/uuid": "^10.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "eslint": "^9.0.0"
    }
}