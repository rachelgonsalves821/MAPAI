{
    "name": "mapai-backend",
    "version": "0.1.0",
    "description": "Mapai Backend API — AI discovery & navigation for Boston",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "lint": "eslint src/ --ext .ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "migrate": "tsx src/db/migration-runner.ts",
        "migrate:status": "tsx src/db/migration-runner.ts --status",
        "migrate:dry-run": "tsx src/db/migration-runner.ts --dry-run",
        "seed": "tsx src/db/seed.ts",
        "pipeline": "tsx src/pipeline/run-pipeline.ts --all",
        "pipeline:seed": "tsx src/pipeline/run-pipeline.ts --seed",
        "pipeline:ingest": "tsx src/pipeline/run-pipeline.ts --ingest"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.39.0",
        "@fastify/cors": "^10.0.0",
        "@fastify/rate-limit": "^10.2.0",
        "@fastify/websocket": "^11.0.0",
        "@google/generative-ai": "^0.24.1",
        "@supabase/supabase-js": "^2.49.0",
        "@types/pg": "^8.18.0",
        "dotenv": "^16.4.7",
        "fastify": "^5.2.0",
        "ioredis": "^5.4.2",
        "jose": "^4.15.9",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.20.0",
        "qrcode": "^1.5.4",
        "svix": "^1.89.0",
        "uuid": "^11.1.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@flydotio/dockerfile": "^0.7.10",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/node": "^22.13.0",
        "@types/qrcode": "^1.5.6",
        "@types/uuid": "^10.0.0",
        "@vitest/coverage-v8": "^2.1.9",
        "eslint": "^9.0.0",
        "pino-pretty": "^13.1.3",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^2.1.9"
    }
}
 
