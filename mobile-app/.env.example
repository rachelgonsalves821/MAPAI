# Environment Configuration
# Copy this file to .env and fill in your real keys

# Google Places API (New) — required for venue search & details
# Get your key at: https://console.cloud.google.com/apis/credentials
# Restrict to: Places API (New), Maps SDK for iOS, Maps SDK for Android
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Anthropic Claude API — required for conversational AI
# Get your key at: https://console.anthropic.com/settings/keys
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase (Sprint 2 — Auth & Database)
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
