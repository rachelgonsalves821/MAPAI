# Mapai Mobile — Environment Variables
# Copy to .env and fill in your values
# See SECRETS.md in project root for key classification
#
# IMPORTANT: Only EXPO_PUBLIC_ prefixed vars are bundled into the app.
# Never put backend-only keys (Anthropic, Gemini, service_role) here.

# Backend API
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001

# Supabase (client-safe anon key only — RLS enforced)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Maps SDK (restrict to bundle ID in Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_SDK_KEY=your_maps_sdk_key_here

# Analytics (write-only keys — safe for client)
EXPO_PUBLIC_SEGMENT_WRITE_KEY=
EXPO_PUBLIC_SENTRY_DSN=
