{
  "expo": {
    "name": "Mapai",
    "slug": "mapai",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mapai",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.mapai.mobile",
      "config": {
        "googleMapsApiKey": "${EXPO_PUBLIC_GOOGLE_MAPS_SDK_KEY}"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Mapai uses your location to show nearby places ranked for you and to get directions to your destination.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Mapai uses your location in the background only to detect when you arrive at a saved destination, so we can send you a quick check-in prompt. You can disable this in Settings at any time.",
        "NSMicrophoneUsageDescription": "Mapai uses your microphone for voice search so you can find places hands-free.",
        "NSContactsUsageDescription": "Mapai can optionally sync your contacts to help you find and add friends. No contact data is stored on our servers.",
        "NSCameraUsageDescription": "Mapai uses your camera to scan QR codes when checking in at partner locations.",
        "NSUserTrackingUsageDescription": "Mapai uses this to personalize your experience and measure how our features are working for you."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePreciseLocation",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeProductInteraction",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAnalytics"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeDeviceID",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAnalytics"
            ]
          }
        ],
        "NSPrivacyTracking": false
      }
    },
    "android": {
      "package": "app.mapai.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#1D3E91"
      },
      "config": {
        "googleMaps": {
          "apiKey": "${EXPO_PUBLIC_GOOGLE_MAPS_SDK_KEY}"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-tracking-transparency",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Mapai uses your location in the background only to detect when you arrive at a saved destination, so we can send you a quick check-in prompt. You can disable this in Settings at any time.",
          "locationWhenInUsePermission": "Mapai uses your location to show nearby places ranked for you and to get directions to your destination.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      "expo-apple-authentication",
      "expo-secure-store",
      ["@sentry/react-native/expo", { "organization": "mapai", "project": "mapai-mobile" }],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0558E8"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Mapai uses your camera to scan QR codes when checking in at partner locations."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Mapai can optionally sync your contacts to help you find and add friends. No contact data is stored on our servers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
